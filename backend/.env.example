# Server
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://inventory_user:inventory_pass@localhost:5432/inventory_db?schema=public"

# JWT
JWT_ACCESS_SECRET=change-this-in-production
JWT_REFRESH_SECRET=change-this-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=inventory@enterprise.com

# CORS
CORS_ORIGIN=http://localhost:5173
